# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Finnhub
FINNHUB_API_KEY=your_finnhub_api_key_here

# IBKR
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password
IBKR_GATEWAY_HOST=ibkr-gateway
IBKR_GATEWAY_PORT=4002

# Database
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading_secret
POSTGRES_DB=trading_db
DATABASE_URL=postgresql+asyncpg://trading:trading_secret@localhost:5432/trading_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# App
SECRET_KEY=change_this_to_a_secure_random_string_at_least_32_chars
ENVIRONMENT=development
LOG_LEVEL=INFO

# Trading Config
DEFAULT_TOP_N=5
DEFAULT_TRADING_MODE=swing
PAPER_TRADING=true

# VNC (for IBKR Gateway GUI access)
VNC_PASSWORD=secret
